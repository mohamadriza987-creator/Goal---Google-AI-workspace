rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────────────

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Admin = custom claim only. Rules can't read env vars, so we refuse to
    // bake an email into the security perimeter. The server still accepts a
    // bootstrap email (via ADMIN_EMAIL env) to let an operator call
    // /api/admin/bootstrap, which sets the 'admin' custom claim — after that
    // the claim alone authorises admin direct-reads through these rules.
    function isAdmin() {
      return isAuthenticated() &&
             (request.auth.token.get('admin', false) == true ||
              request.auth.token.get('role', '') == 'admin');
    }

    function isGoalOwner(goalId) {
      return isAuthenticated() &&
             get(/databases/$(database)/documents/goals/$(goalId)).data.ownerId == request.auth.uid;
    }

    // ── Health check ─────────────────────────────────────────────────

    match /test/{docId} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    // ── Users ────────────────────────────────────────────────────────
    // Users can only fully read/write their own document.
    // Other users can read a limited public profile (for room member display).
    // Sensitive fields (hiddenUsers, blockedUsers, trustSignals) are never
    // intentionally rendered from another user's doc on the client.

    match /users/{userId} {
      allow read:   if isOwner(userId) || isAdmin() || isAuthenticated();
      allow create: if isOwner(userId) &&
                       request.resource.data.keys().hasOnly([
                         'displayName', 'username', 'avatarUrl', 'bio',
                         'locality', 'geohash', 'lat', 'lng',
                         'preferredLanguage', 'hiddenUsers', 'blockedUsers',
                         'trustSignals', 'createdAt', 'updatedAt'
                       ]);
      allow update: if isOwner(userId) &&
                       request.resource.data.keys().hasOnly([
                         'displayName', 'username', 'avatarUrl', 'bio',
                         'locality', 'geohash', 'lat', 'lng',
                         'preferredLanguage', 'hiddenUsers', 'blockedUsers',
                         'trustSignals', 'createdAt', 'updatedAt'
                       ]);

      match /calendarNotes/{noteId} {
        allow read:  if isOwner(userId) || isAdmin();
        allow write: if isOwner(userId);
      }
    }

    // ── Goals ────────────────────────────────────────────────────────

    match /goals/{goalId} {
      allow read:   if isAuthenticated() &&
                       (resource.data.ownerId == request.auth.uid ||
                        resource.data.visibility == 'public' ||
                        isAdmin());
      allow create: if isAuthenticated() &&
                       request.resource.data.ownerId == request.auth.uid;
      allow update: if isAuthenticated() &&
                       resource.data.ownerId == request.auth.uid;
      allow delete: if isAuthenticated() &&
                       resource.data.ownerId == request.auth.uid;

      match /tasks/{taskId} {
        allow read:  if isGoalOwner(goalId) || isAdmin();
        allow write: if isGoalOwner(goalId) || isAdmin();
      }

      match /notes/{noteId} {
        allow read:  if isGoalOwner(goalId) || isAdmin();
        allow write: if isGoalOwner(goalId) || isAdmin();
      }
    }

    // ── Collection-group queries (calendar reminders) ─────────────────
    // SECURITY FIX: Verify the intermediate goal path belongs to the user.
    // path here is the full path to the parent goal document, e.g.
    //   goals/{goalId}
    // The get() call returns that goal doc so we can check ownerId.

    match /{path=**}/tasks/{taskId} {
      allow read: if isAuthenticated() &&
                     get(/databases/$(database)/documents/$(path)).data.ownerId == request.auth.uid;
    }

    match /{path=**}/notes/{noteId} {
      allow read: if isAuthenticated() &&
                     get(/databases/$(database)/documents/$(path)).data.ownerId == request.auth.uid;
    }

    // ── Groups / Goal Rooms ───────────────────────────────────────────
    // SECURITY FIX: No longer allow all authenticated users to read all groups.
    // Users may only read a group if:
    //   (a) they are a confirmed member  (memberIds[] written server-side), OR
    //   (b) they are eligible            (their goalId is in eligibleGoalIds[])
    //
    // All writes go through server endpoints (Admin SDK bypasses these rules).

    match /groups/{groupId} {
      // Client direct reads are members-only. Previously the rule also
      // admitted anyone authenticated if eligibleGoalIds was non-empty —
      // which in practice meant any group with any eligible goal was
      // world-readable. Eligibility-based previews now route through
      // /api/groups/:groupId, which enforces "member OR owns an eligible
      // goal" server-side without widening the rule.
      allow read: if isAdmin() ||
                    (isAuthenticated() &&
                       request.auth.uid in resource.data.get('memberIds', []));
      allow write: if false;
    }

    // Support threads — group members only.
    match /groups/{groupId}/threads/{threadId} {
      allow read:   if isAdmin() ||
                      (isAuthenticated() &&
                         request.auth.uid in
                           get(/databases/$(database)/documents/groups/$(groupId)).data.get('memberIds', []));
      allow create: if isAuthenticated() &&
                       request.auth.uid in
                         get(/databases/$(database)/documents/groups/$(groupId)).data.get('memberIds', []) &&
                       request.resource.data.authorId == request.auth.uid;
      // Members may increment replyCount (+1), lastActivityAt (string), or usefulCount (+1).
      // No other fields may be touched. Each counter is monotonically increasing only.
      allow update: if isAdmin() ||
                      (isAuthenticated() &&
                         request.auth.uid in
                           get(/databases/$(database)/documents/groups/$(groupId)).data.get('memberIds', []) &&
                         request.resource.data.diff(resource.data).affectedKeys()
                           .hasOnly(['replyCount', 'lastActivityAt', 'usefulCount']) &&
                         (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['replyCount']) ||
                           request.resource.data.replyCount == resource.data.get('replyCount', 0) + 1) &&
                         (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['usefulCount']) ||
                           request.resource.data.usefulCount == resource.data.get('usefulCount', 0) + 1));
      allow delete: if isAdmin();
    }

    match /groups/{groupId}/threads/{threadId}/replies/{replyId} {
      allow read:   if isAdmin() ||
                      (isAuthenticated() &&
                         request.auth.uid in
                           get(/databases/$(database)/documents/groups/$(groupId)).data.get('memberIds', []));
      allow create: if isAuthenticated() &&
                       request.auth.uid in
                         get(/databases/$(database)/documents/groups/$(groupId)).data.get('memberIds', []) &&
                       request.resource.data.authorId == request.auth.uid;
      // Members may only update the reactions map.
      // Each known reaction key is monotonically increasing — values cannot decrease.
      allow update: if isAdmin() ||
                      (isAuthenticated() &&
                         request.auth.uid in
                           get(/databases/$(database)/documents/groups/$(groupId)).data.get('memberIds', []) &&
                         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactions']) &&
                         request.resource.data.reactions.get('useful',   0) >= resource.data.get('reactions', {}).get('useful',   0) &&
                         request.resource.data.reactions.get('proud',    0) >= resource.data.get('reactions', {}).get('proud',    0) &&
                         request.resource.data.reactions.get('me_too',   0) >= resource.data.get('reactions', {}).get('me_too',   0) &&
                         request.resource.data.reactions.get('can_help', 0) >= resource.data.get('reactions', {}).get('can_help', 0));
      allow delete: if isAdmin();
    }

    // ── One-time media ───────────────────────────────────────────────

    match /one_time_media/{mediaId} {
      allow read:  if isAuthenticated();
      allow write: if false;
    }

    // ── Reports ──────────────────────────────────────────────────────

    match /reports/{reportId} {
      allow read:   if isAdmin();
      allow create: if isAuthenticated() &&
                       request.resource.data.reporterId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── Moderation events ────────────────────────────────────────────

    match /moderation_events/{eventId} {
      allow read:   if isAdmin();
      // Previously any authenticated user could write arbitrary fields here.
      // Lock to a known shape; reporterId must match the caller so moderators
      // can trust it as the real author.
      allow create: if isAuthenticated() &&
                       request.resource.data.keys().hasOnly([
                         'reporterId', 'targetUserId', 'action',
                         'context', 'createdAt', 'status'
                       ]) &&
                       request.resource.data.reporterId == request.auth.uid &&
                       request.resource.data.targetUserId is string &&
                       request.resource.data.targetUserId.size() > 0 &&
                       request.resource.data.targetUserId != request.auth.uid &&
                       request.resource.data.action in ['hide', 'block', 'report'];
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
  }
}
