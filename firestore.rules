rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────────────

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Admin = your verified email only.
    // Does NOT rely on a writable 'role' field (that would be a security hole).
    function isAdmin() {
      return isAuthenticated() &&
             request.auth.token.email_verified == true &&
             request.auth.token.email == "mohamadriza987@gmail.com";
    }

    // ── Health check ─────────────────────────────────────────────────
    // The server's /api/health reads from 'test' collection.

    match /test/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Users ────────────────────────────────────────────────────────
    // Each user can read and write ONLY their own document.
    // 'role' is intentionally excluded from writable fields.

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) &&
                       request.resource.data.keys().hasOnly([
                         'displayName', 'username', 'avatarUrl', 'bio',
                         'locality', 'geohash', 'lat', 'lng',
                         'preferredLanguage', 'hiddenUsers', 'blockedUsers',
                         'trustSignals', 'createdAt', 'updatedAt'
                       ]);
      allow update: if isOwner(userId) &&
                       request.resource.data.keys().hasOnly([
                         'displayName', 'username', 'avatarUrl', 'bio',
                         'locality', 'geohash', 'lat', 'lng',
                         'preferredLanguage', 'hiddenUsers', 'blockedUsers',
                         'trustSignals', 'createdAt', 'updatedAt'
                       ]);
    }

    // ── Goals ────────────────────────────────────────────────────────

    match /goals/{goalId} {
      allow read: if isAuthenticated() &&
                     (resource.data.ownerId == request.auth.uid ||
                      resource.data.visibility == 'public' ||
                      isAdmin());
      allow create: if isAuthenticated() &&
                       request.resource.data.ownerId == request.auth.uid;
      allow update: if isAuthenticated() &&
                       resource.data.ownerId == request.auth.uid;
      allow delete: if isAuthenticated() &&
                       resource.data.ownerId == request.auth.uid;

      match /tasks/{taskId} {
        allow read: if isAuthenticated() &&
                       get(/databases/$(database)/documents/goals/$(goalId)).data.ownerId == request.auth.uid;
        allow write: if isAuthenticated() &&
                        get(/databases/$(database)/documents/goals/$(goalId)).data.ownerId == request.auth.uid;
      }

      match /notes/{noteId} {
        allow read: if isAuthenticated() &&
                       get(/databases/$(database)/documents/goals/$(goalId)).data.ownerId == request.auth.uid;
        allow write: if isAuthenticated() &&
                        get(/databases/$(database)/documents/goals/$(goalId)).data.ownerId == request.auth.uid;
      }
    }

    // Collection-group queries for the calendar reminders screen
    match /{path=**}/tasks/{taskId} {
      allow read: if isAuthenticated();
    }
    match /{path=**}/notes/{noteId} {
      allow read: if isAuthenticated();
    }

    // ── Groups ───────────────────────────────────────────────────────
    // All group writes go through server endpoints (Admin SDK bypasses rules).
    // Clients only need to READ group docs to display group info.
    // NOTE: membership is stored as a members[] array on the group doc,
    // NOT as a /members subcollection — the old rules checked a subcollection
    // that never existed, which caused all the PERMISSION_DENIED errors.

    match /groups/{groupId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    // ── One-time media ───────────────────────────────────────────────

    match /one_time_media/{mediaId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    // ── Reports ──────────────────────────────────────────────────────

    match /reports/{reportId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated() &&
                       request.resource.data.reporterId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── Moderation events ────────────────────────────────────────────

    match /moderation_events/{eventId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
    }
  }
}
