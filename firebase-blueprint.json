{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "displayName": { "type": "string" },
        "username": { "type": "string" },
        "avatarUrl": { "type": "string" },
        "bio": { "type": "string" },
        "locality": { "type": "string" },
        "geohash": { "type": "string" },
        "lat": { "type": "number" },
        "lng": { "type": "number" },
        "preferredLanguage": { "type": "string" },
        "hiddenUsers": { "type": "array", "items": { "type": "string" } },
        "blockedUsers": { "type": "array", "items": { "type": "string" } },
        "trustSignals": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "displayName", "username", "createdAt"]
    },
    "Goal": {
      "title": "Goal",
      "description": "User's goal with AI-structured content",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "ownerId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "originalVoiceTranscript": { "type": "string" },
        "originalLanguage": { "type": "string" },
        "aiGeneratedTitle": { "type": "string" },
        "aiGeneratedDescription": { "type": "string" },
        "visibility": { "type": "string", "enum": ["private", "group", "public"] },
        "publicFields": { "type": "array", "items": { "type": "string" } },
        "category": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "completed", "archived"] },
        "progressPercent": { "type": "number" },
        "likesCount": { "type": "integer" },
        "groupId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "ownerId", "title", "createdAt"]
    },
    "GoalTask": {
      "title": "GoalTask",
      "description": "Actionable task for a goal",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "goalId": { "type": "string" },
        "text": { "type": "string" },
        "source": { "type": "string", "enum": ["ai", "user"] },
        "order": { "type": "integer" },
        "isDone": { "type": "boolean" },
        "completedAt": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "goalId", "text", "createdAt"]
    },
    "GoalNote": {
      "title": "GoalNote",
      "description": "Note attached to a goal",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "goalId": { "type": "string" },
        "ownerId": { "type": "string" },
        "sourceType": { "type": "string", "enum": ["manual", "community_message", "ai_suggestion"] },
        "sourceMessageId": { "type": "string" },
        "text": { "type": "string" },
        "privateComment": { "type": "string" },
        "reminderAt": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "goalId", "ownerId", "text", "createdAt"]
    },
    "Group": {
      "title": "Group",
      "description": "Community group for similar goals",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "derivedGoalTheme": { "type": "string" },
        "localityCenter": { "type": "string" },
        "geohash": { "type": "string" },
        "lat": { "type": "number" },
        "lng": { "type": "number" },
        "radiusUsed": { "type": "number" },
        "targetRegion": { "type": "string" },
        "memberCount": { "type": "integer" },
        "maxMembers": { "type": "integer" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "derivedGoalTheme", "createdAt"]
    },
    "GroupMember": {
      "title": "GroupMember",
      "description": "Membership in a group",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "groupId": { "type": "string" },
        "userId": { "type": "string" },
        "goalId": { "type": "string" },
        "joinedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "groupId", "userId", "joinedAt"]
    },
    "CommunityMessage": {
      "title": "CommunityMessage",
      "description": "Message in a group feed",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "groupId": { "type": "string" },
        "userId": { "type": "string" },
        "content": { "type": "string" },
        "contentType": { "type": "string", "enum": ["text", "image", "video", "link", "poll"] },
        "replyToMessageId": { "type": "string" },
        "threadRootId": { "type": "string" },
        "reactions": { "type": "object" },
        "attachmentMetadata": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "groupId", "userId", "content", "createdAt"]
    },
    "ModerationEvent": {
      "title": "ModerationEvent",
      "description": "Trust and safety signal",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "actorUserId": { "type": "string" },
        "targetUserId": { "type": "string" },
        "eventType": { "type": "string", "enum": ["hide", "block", "report"] },
        "contextType": { "type": "string" },
        "contextId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "actorUserId", "targetUserId", "eventType", "createdAt"]
    },
    "Report": {
      "title": "Report",
      "description": "User report for inappropriate behavior",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "reporterId": { "type": "string" },
        "reportedUserId": { "type": "string" },
        "messageId": { "type": "string" },
        "reason": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "reviewed", "resolved"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "reporterId", "reportedUserId", "reason", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": { "schema": "User", "description": "User profiles" },
    "/goals/{goalId}": { "schema": "Goal", "description": "User goals" },
    "/goals/{goalId}/tasks/{taskId}": { "schema": "GoalTask", "description": "Goal tasks" },
    "/goals/{goalId}/notes/{noteId}": { "schema": "GoalNote", "description": "Goal notes" },
    "/groups/{groupId}": { "schema": "Group", "description": "Community groups" },
    "/groups/{groupId}/members/{memberId}": { "schema": "GroupMember", "description": "Group memberships" },
    "/groups/{groupId}/messages/{messageId}": { "schema": "CommunityMessage", "description": "Group messages" },
    "/moderation_events/{eventId}": { "schema": "ModerationEvent", "description": "Moderation logs" },
    "/reports/{reportId}": { "schema": "Report", "description": "User reports" }
  }
}
